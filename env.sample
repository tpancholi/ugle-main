KEYGEN_PRODUCT_TOKEN=<product token>
KEYGEN_ACCOUNT_ID=<account id>
KEYGEN_PRODUCT_ID=<product id>
KEYGEN_POLICY_TRIAL=<policy id>
KEYGEN_POLICY_MONTHLY=<policy id>
KEYGEN_POLICY_ANNUAL=<policy id>

CASHFREE_ENV=sandbox
CASHFREE_APP_ID=<app id>
CASHFREE_SECRET_KEY=<secret key>

DATABASE_URL=postgresql://...
NEXT_PUBLIC_APP_URL=http://localhost:3000
SUPPORT_EMAIL=support@ugle.ai
# Required for manage-link JWTs (do not reuse KEYGEN_PRODUCT_TOKEN)
MANAGE_LICENSE_SECRET=<random-32+-char-secret>
# Set to true to test the checkout pipeline WITHOUT creating real Keygen
# licences (no quota used). Unset/false for production.
KEYGEN_MOCK=false
RESEND_API_KEY=<api_key>
RESEND_FROM_EMAIL=no-reply@contact.ugle.ai
ADMIN_EMAIL=support@ugle.ai
